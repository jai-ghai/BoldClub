APP_NAME=BoldClub API
ENVIRONMENT=development
API_V1_PREFIX=/v1
SQL_ECHO=false
AUTO_CREATE_TABLES=true
BACKEND_CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006,http://127.0.0.1:19006,http://localhost:3000,http://127.0.0.1:3000

POSTGRES_DSN=postgresql+asyncpg://boldclub:boldclub@localhost:5432/boldclub
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRY_MINUTES=60
REFRESH_TOKEN_EXPIRY_DAYS=30

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_COMPATIBILITY_MODEL=gpt-4o-mini

STREAM_API_KEY=
STREAM_API_SECRET=

OTP_EMAIL_PROVIDER=development
OTP_SMS_PROVIDER=development
OTP_EMAIL_FROM=
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

